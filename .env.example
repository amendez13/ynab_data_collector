# Environment variables for YNAB Data Collector
# Copy this file to .env and fill in your values:
#   cp .env.example .env
#
# WARNING: .env contains sensitive data and should NOT be committed to git

# =============================================================================
# YNAB API Configuration
# =============================================================================

# YNAB Personal Access Token (REQUIRED)
# Get yours at: https://app.ynab.com/settings/developer
# 1. Go to YNAB Settings -> Developer Settings
# 2. Click "New Token"
# 3. Give it a name and copy the token
# 4. Paste it below (replace 'your_token_here')
YNAB_API_TOKEN=your_token_here
